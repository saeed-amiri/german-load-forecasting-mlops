# Copy to .env for local use.
# Required: used by docker-compose.yml image/build args.
IMAGE_TAG=dev

# Optional local overrides
API_PORT=8000
AIRFLOW_PORT=8082
APP_UID=1000
APP_GID=1000

# Optional Airflow admin credentials (used by `make airflow-reset-admin`)
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_ROLE=Admin

# Optional Grafana admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Optional MLflow defaults (used by training and Airflow)
# If MLFLOW_TRACKING_URI is set, that is what is used.
# If not, then training.yml decides via tracking_uri or tracking_mode fallback.
MLFLOW_TRACKING_MODE=server
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_PORT=5001

# Optional DagsHub MLflow tracking credentials
# For DagsHub, set MLFLOW_TRACKING_MODE=dagshub and define:
DAGSHUB_REPO=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
